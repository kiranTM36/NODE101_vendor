<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products</title>

  <style>
    * {
      box-sizing: border-box;
      padding: 0;
      margin: 0;
    }
    body{
        background-color: #f9f9f9;
        height: 100vh;
    }
    .main-container{
        position: relative;
        padding: 20px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
    .C-product{
    background-color: #ffffff;
    box-shadow: 5px 5px 10px rgba(0,0,0,0.3);
    border-radius: 10px;
    height: 40vh;
    width: 15%;
    flex-shrink: 0;
    transition: 0.3s;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 1vh;
    position: relative;
    transition: all 0.3s ease-in-out;
    top: 15vh;
}
.C-product:hover{
    transform: scale(1.04);
}
.img{
    width: 96%;
    height: 50%;
    background-color: #f5f5f5;
    border-radius: 10px;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
}

.P-text{
    width: 96%;
    height: 25%;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
    padding-left: 10px;
}
.default-txt{
    font-weight: bold;
    color: #000;
}
.P-btn{
    width: 96%;
    height: 15%;
    display: flex;
    gap: 1vh;
}
.B-btn, .btn-b{
    width: 50%;
    padding: 10px;
    font-weight: bold;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
}
.btn-a{
    width: 50%;   
}
.B-btn:nth-child(1){
    background-color: #1395ff;
}
.B-btn:nth-child(2){
    background-color: rgb(0, 205, 0);
}
.btn-b{
    height: 100%;
    width: 100%;
    background-color: rgb(0, 205, 0);
}
.B-btn:hover{
    transform: scale(1.05);
}
span{
    font-weight: normal;
}

  </style>
</head>

<body>

  <%- include('navBar') %>

  <div class="main-container">
    <% data.forEach((item) => { %>

       <div class="C-product" onclick="window.location.href='/product/details/<%= item._id %>'">
            <div class="img" style="background-image: url('/uploads/<%= item.productImg %>');"></div>

                <div class="P-text">
                    <p class="default-txt">Name : <span><%- item.productName %></span> </p>
                    <p class="default-txt">Price : <span><%- item.price %></span></p>
                    <p class="default-txt">Status : <span><%- item.status %></span></p>
                </div>

                <div class="P-btn">
                    <button class="B-btn">
                        <i class="fa-solid fa-cart-arrow-down"></i> Buy
                    </button>

                        <button class="B-btn">
                            <i class="fa-solid fa-eye"></i> View
                        </button>
                </div>
             </div>
           

    <% }) %>
  </div>

</body>
</html>